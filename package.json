{
  "name": "game-of-thrones-site",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:unit": "vitest run --environment jsdom --exclude tests/site.spec.js",
    "test:unit:coverage": "vitest run --environment jsdom --coverage --exclude tests/site.spec.js",
    "test:e2e": "playwright test",
    "serve": "http-server . -p 8080"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@playwright/test": "^1.54.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.23.0",
    "http-server": "^14.1.1",
    "jsdom": "^26.1.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "lightgallery": "^2.8.3",
    "posthog-js": "^1.365.3"
  }
}
